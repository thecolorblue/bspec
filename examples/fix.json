{
  "build": { "cmd": "npm run build" },
  "test": { "cmd": "npm test" },
  "protected": [
    "**/*.test.*",
    "**/*.spec.*",
    "tests/**",
    "spec/**",
    "**/conftest.py",
    "**/vitest.config.*",
    "**/jest.config.*"
  ],
  "maxIters": 12,
  "tokenBudget": 2000000,
  "buildTimeoutMs": 300000,
  "testTimeoutMs": 600000,
  "allowShell": false,
  "snapshotIgnore": [".git", "node_modules", ".bspec", ".DS_Store", "dist", ".next", "build"]
}
