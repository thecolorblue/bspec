{
  "name": "bspec",
  "version": "0.0.0",
  "description": "a CLI agent harness, built with Pi and bun, that takes a SPEC.md file and builds a complete functional application.",
  "type": "module",
  "private": true,
  "bin": {
    "bspec": "src/cli.ts"
  },
  "scripts": {
    "bspec": "bun run src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build:bin": "bun build ./src/cli.ts --outfile ./dist/bspec --compile"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@earendil-works/pi-tui": "^0.76.0",
    "@juicesharp/rpiv-ask-user-question": "^1.20.0",
    "@juicesharp/rpiv-todo": "^1.20.0",
    "commander": "^12.1.0",
    "tar": "^7.4.3",
    "typebox": "^1.1.38",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.1.0",
    "typescript": "^5.5.0"
  }
}
